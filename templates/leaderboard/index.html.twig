{% extends 'base.html.twig' %}

{% block title %}Tabla de posiciones{% endblock %}

{% block body %}
<h1 class="h3 mb-3">Tabla de posiciones</h1>

{% if nextFixture %}
    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <div class="fw-semibold">Próximo partido a cerrar</div>
                <div>
                    {{ nextFixture.homeTeam.code|flag_icon }} {{ nextFixture.homeTeam.code|country_name_es(nextFixture.homeTeam.name) }}
                    vs
                    {{ nextFixture.awayTeam.code|flag_icon }} {{ nextFixture.awayTeam.code|country_name_es(nextFixture.awayTeam.name) }}
                </div>
                <small class="text-body-secondary d-block mt-1">Ese es el partido que más pronto cierra para cargar o editar tu pronóstico.</small>
            </div>
            <small class="text-body-secondary">
                Cierre: <span class="js-local-datetime" data-utc="{{ nextFixture.kickoffAt|date_modify('-5 minutes')|date('c') }}">{{ nextFixture.kickoffAt|date_modify('-5 minutes')|date('Y-m-d H:i') }} UTC</span>
            </small>
        </div>
    </div>
{% endif %}

<div class="row g-4 align-items-start">
    <div class="col-lg-4">
        <div class="mb-2 d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Usuarios</h2>
            <span class="badge bg-primary">Faltan {{ remainingCount }} partido{{ remainingCount == 1 ? '' : 's' }} sin finalizar</span>
        </div>
        <p class="screen-note mb-2">Los <strong>+X</strong> son puntos en vivo antes del cierre. El ranking oficial se fija cuando el partido finaliza.</p>
        <div class="table-responsive bg-white border rounded-3 shadow-sm">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Participante</th>
                        <th class="text-center">Puntos</th>
                        <th class="text-center">Aciertos exactos</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        {% set livePoints = livePointsByUser[row.userId]|default(0) %}
                        {% set streak = streakByUser[row.userId]|default(0) %}
                        <tr class="{{ app.user and row.userId == app.user.id ? 'table-row-current-user' : '' }}">
                            <td>{{ row.rank }}</td>
                            <td>
                                {% if row.rank == 1 %}
                                    <strong style="color: #D4AF37;">{{ row.name }}</strong>
                                {% elseif row.rank == 2 %}
                                    <strong style="color: #C0C0C0;">{{ row.name }}</strong>
                                {% elseif row.rank == 3 %}
                                    <strong style="color: #CD7F32;">{{ row.name }}</strong>
                                {% else %}
                                    {{ row.name }}
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <strong>{{ row.points }}</strong>
                                {% if livePoints > 0 %}
                                    <span class="text-info fw-semibold">+{{ livePoints }}</span>
                                {% endif %}
                            </td>
                            <td class="text-center">{{ row.exactHits }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="text-center py-4">Sin datos todavía.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-8">
        <h2 class="h5 mb-2">Partidos por grupo</h2>
        <div class="row g-3">
            {% for groupCode, fixtures in fixturesByGroup %}
                {% set modalId = 'group-predictions-' ~ loop.index %}
                <div class="col-12 col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-header fw-semibold d-flex justify-content-between align-items-center gap-2">
                            <span>Grupo {{ groupCode }}</span>
                            <button
                                type="button"
                                class="btn btn-outline-dark btn-sm"
                                data-open-predictions="{{ modalId }}"
                            >Ver predicciones</button>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0 group-fixtures-table">
                                    <tbody>
                                        {% for fixture in fixtures %}
                                            {% set kickoffTs = fixture.kickoffAt|date('U') %}
                                            {% set nowTs = 'now'|date('U') %}
                                            {% set hasLoadedScore = fixture.homeScore is not null and fixture.awayScore is not null %}
                                            {% set isInProgress = fixture.status == 'scheduled' and (kickoffTs <= nowTs or hasLoadedScore) %}
                                            {% set isFinished = fixture.status == 'finished' %}
                                            <tr>
                                                <td class="fw-semibold team-cell team-cell-home">
                                                    {{ fixture.homeTeam.code|flag_icon }} {{ fixture.homeTeam.code|country_name_es(fixture.homeTeam.name) }}
                                                </td>
                                                <td class="text-center fw-bold score-cell">
                                                    {% if isFinished %}
                                                        <small class="d-block mb-1"><span class="badge text-bg-secondary">Finalizado</span></small>
                                                    {% elseif isInProgress %}
                                                        <small class="d-block mb-1"><span class="badge text-bg-info">En curso</span></small>
                                                    {% endif %}
                                                    {% if hasLoadedScore %}
                                                        {{ fixture.homeScore }} - {{ fixture.awayScore }}
                                                    {% else %}
                                                        &nbsp;
                                                    {% endif %}
                                                    <small class="d-block text-body-secondary fw-normal mt-1 js-local-datetime kickoff-time" data-utc="{{ fixture.kickoffAt|date('c') }}">{{ fixture.kickoffAt|date('Y-m-d H:i') }} UTC</small>
                                                </td>
                                                <td class="fw-semibold text-end team-cell team-cell-away">
                                                    {{ fixture.awayTeam.code|country_name_es(fixture.awayTeam.name) }} {{ fixture.awayTeam.code|flag_icon }}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="prediction-modal" id="{{ modalId }}" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="{{ modalId }}-title">
                    <div class="prediction-modal__backdrop" data-close-predictions="{{ modalId }}"></div>
                    <div class="prediction-modal__panel" role="document">
                        <div class="prediction-modal__header d-flex justify-content-between align-items-center gap-2">
                            <h3 class="h5 mb-0" id="{{ modalId }}-title">Predicciones Grupo {{ groupCode }}</h3>
                            <button type="button" class="btn btn-outline-dark btn-sm" data-close-predictions="{{ modalId }}">Cerrar</button>
                        </div>
                        <div class="prediction-modal__body">
                            <p class="text-body-secondary small mb-3">Aquí solo se muestran predicciones de partidos ya cerrados a edición.</p>
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <tbody>
                                        {% for fixtureId, fixtureData in predictionsByGroup[groupCode]|default([]) %}
                                            {% set fixture = fixtureData.fixture %}
                                            {% set predictions = fixtureData.predictions %}
                                            
                                            <tr>
                                                <td colspan="3" class="py-2 px-3" style="background-color: var(--wc-bg-soft); border-bottom: 1px solid var(--wc-line);">
                                                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                                        <span class="fw-bold text-white">
                                                            {{ fixture.homeTeam.code|flag_icon }} {{ fixture.homeTeam.code|country_name_es(fixture.homeTeam.name) }}
                                                            <span style="color: var(--wc-muted); margin: 0 4px;">vs</span>
                                                            {{ fixture.awayTeam.code|flag_icon }} {{ fixture.awayTeam.code|country_name_es(fixture.awayTeam.name) }}
                                                        </span>
                                                        
                                                        <div class="d-flex align-items-center gap-2">
                                                            <span class="small js-local-datetime" style="color: var(--wc-muted);" data-utc="{{ fixture.kickoffAt|date('c') }}">
                                                                {{ fixture.kickoffAt|date('Y-m-d H:i') }} UTC
                                                            </span>
                                                            
                                                            {% set kickoffTs = fixture.kickoffAt|date('U') %}
                                                            {% set nowTs = 'now'|date('U') %}
                                                            {% set hasLoadedScore = fixture.homeScore is not null and fixture.awayScore is not null %}
                                                            {% set isInProgress = fixture.status == 'scheduled' and (kickoffTs <= nowTs or hasLoadedScore) %}
                                                            {% set isFinished = fixture.status == 'finished' %}
                                                            
                                                            {% if isFinished %}
                                                                <span class="badge text-bg-secondary">Finalizado: {{ fixture.homeScore }} - {{ fixture.awayScore }}</span>
                                                            {% elseif isInProgress %}
                                                                <span class="badge text-bg-info">En curso: {{ fixture.homeScore }} - {{ fixture.awayScore }}</span>
                                                            {% else %}
                                                                <span class="badge text-bg-dark border border-secondary text-secondary">Programado</span>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                            
                                            {% if predictions is not empty %}
                                                <tr class="small" style="font-size: 0.8rem; border-bottom: 1px solid rgba(156, 179, 197, 0.15);">
                                                    <th class="ps-3 py-2 border-bottom-0" style="color: var(--wc-muted);">Usuario</th>
                                                    <th class="py-2 border-bottom-0" style="color: var(--wc-muted);">Predicción</th>
                                                    <th class="pe-3 py-2 text-end border-bottom-0" style="color: var(--wc-muted);">Puntos</th>
                                                </tr>
                                                
                                                {% for prediction in predictions %}
                                                    {% set points = scoringService.calculatePoints(prediction) %}
                                                    <tr style="border-bottom: 1px solid rgba(156, 179, 197, 0.08);">
                                                        <td class="ps-3 py-2" style="color: var(--wc-text);">{{ prediction.user.name }}</td>
                                                        <td class="py-2"><strong style="color: var(--wc-accent);">{{ prediction.predictedHomeScore }} - {{ prediction.predictedAwayScore }}</strong></td>
                                                        <td class="pe-3 py-2 text-end">
                                                            {% if fixture.status == 'finished' %}
                                                                {% if points == 3 %}
                                                                    <span class="badge text-bg-success fw-semibold">+3 pts</span>
                                                                {% elseif points == 1 %}
                                                                    <span class="badge text-bg-primary fw-semibold">+1 pt</span>
                                                                {% else %}
                                                                    <span class="badge text-bg-dark border border-secondary text-muted fw-normal">0 pts</span>
                                                                {% endif %}
                                                            {% else %}
                                                                <span style="color: var(--wc-muted); font-size: 0.9rem;">-</span>
                                                            {% endif %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            {% else %}
                                                <tr class="border-bottom-0">
                                                    <td colspan="3" class="ps-3 text-muted small py-2">Sin predicciones registradas para este partido.</td>
                                                </tr>
                                            {% endif %}
                                            <tr style="height: 12px; border: none;"><td colspan="3" style="border: none; padding: 0;"></td></tr>
                                        {% else %}
                                            <tr>
                                                <td class="text-center py-4" style="color: var(--wc-muted);">No hay predicciones de partidos cerrados en este grupo.</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info mb-0">No hay partidos cargados todavía.</div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            if (window.__groupPredictionsModalBound) {
                return;
            }
            window.__groupPredictionsModalBound = true;

            const openModal = (id) => {
                const modal = document.getElementById(id);
                if (!modal) {
                    return;
                }

                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('has-open-modal');
            };

            const closeModal = (id) => {
                const modal = document.getElementById(id);
                if (!modal) {
                    return;
                }

                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');

                if (!document.querySelector('.prediction-modal.is-open')) {
                    document.body.classList.remove('has-open-modal');
                }
            };

            document.addEventListener('click', (event) => {
                const openTrigger = event.target.closest('[data-open-predictions]');
                if (openTrigger) {
                    openModal(openTrigger.dataset.openPredictions);
                    return;
                }

                const closeTrigger = event.target.closest('[data-close-predictions]');
                if (closeTrigger) {
                    closeModal(closeTrigger.dataset.closePredictions);
                }
            });

            document.addEventListener('keydown', (event) => {
                if (event.key !== 'Escape') {
                    return;
                }

                document.querySelectorAll('.prediction-modal.is-open').forEach((modal) => {
                    closeModal(modal.id);
                });
            });
        })();
    </script>
{% endblock %}
