<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Quiniela 2026{% endblock %}</title>
        {% block head_meta %}{% endblock %}

        {# PWA #}
        <link rel="manifest" href="/manifest.webmanifest">
        <meta name="theme-color" content="#E4002B">
        <link rel="icon" href="/img/icon-192.png">
        <link rel="apple-touch-icon" href="/img/apple-touch-icon.png">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <meta name="apple-mobile-web-app-title" content="Quiniela 2026">
        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script>
                (() => {
                    // Iconos Lucide (línea) por franja horaria, según la hora local.
                    const DAYPART_ICONS = {
                        madrugada: '<path d="M18 5h4"/><path d="M20 3v4"/><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/>',
                        dia: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>',
                        noche: '<path d="M12 10V2"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/>',
                    };
                    const DAYPART_LABELS = { madrugada: 'Madrugada', dia: 'Día', noche: 'Noche' };
                    const dayPartKey = (h) => (h < 6 ? 'madrugada' : (h < 19 ? 'dia' : 'noche'));
                    const dayPartSvg = (key) =>
                        '<svg class="daypart-icon daypart-icon--' + key + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + DAYPART_ICONS[key] + '</svg>';

                    const renderLocalDates = () => {
                        document.querySelectorAll('.js-local-datetime').forEach((element) => {
                            const date = new Date(element.dataset.utc);

                            if (Number.isNaN(date.getTime())) {
                                return;
                            }

                            const formatted = new Intl.DateTimeFormat('es-419', {
                                year: 'numeric',
                                month: '2-digit',
                                day: '2-digit',
                                hour: '2-digit',
                                minute: '2-digit',
                                hour12: false,
                            }).format(date);

                            if (element.hasAttribute('data-daypart')) {
                                const key = dayPartKey(date.getHours());
                                element.innerHTML = dayPartSvg(key) + '<span>' + formatted + '</span>';
                                element.title = DAYPART_LABELS[key];
                                element.setAttribute('aria-label', DAYPART_LABELS[key] + ': ' + formatted);
                            } else {
                                element.textContent = formatted;
                            }
                        });
                    };

                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', renderLocalDates);
                    } else {
                        renderLocalDates();
                    }

                    document.addEventListener('turbo:load', renderLocalDates);
                    // Los Turbo Frames con carga diferida (p. ej. "partidos de hoy" en el
                    // home) disparan turbo:frame-load, no turbo:load. Sin esto, las fechas
                    // inyectadas en el frame se quedarían en UTC.
                    document.addEventListener('turbo:frame-load', renderLocalDates);

                    // Toggle del menú hamburguesa con soporte para clics fuera
                    document.addEventListener('click', (e) => {
                        const toggleBtn = e.target.closest('#navbarToggle');
                        const menu = document.getElementById('navbarMenu');
                        
                        if (toggleBtn) {
                            if (menu) {
                                menu.classList.toggle('show');
                                const isExpanded = menu.classList.contains('show');
                                toggleBtn.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');
                            }
                        } else if (menu && menu.classList.contains('show')) {
                            if (!e.target.closest('#navbarMenu')) {
                                menu.classList.remove('show');
                                const btn = document.getElementById('navbarToggle');
                                if (btn) {
                                    btn.setAttribute('aria-expanded', 'false');
                                }
                            }
                        }
                    });
                })();
            </script>

            {# Registro del service worker (PWA) #}
            <script>
                if ('serviceWorker' in navigator) {
                    window.addEventListener('load', () => {
                        navigator.serviceWorker.register('/sw.js').catch(() => {});
                    });
                }
            </script>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_home') }}">
                    <img src="/img/icon-192.png" alt="" width="30" height="30" class="rounded">
                    <span>Quiniela 2026</span>
                </a>
                <button class="navbar-toggler" type="button" id="navbarToggle" aria-controls="navbarMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMenu">
                    <div class="navbar-nav ms-auto">
                        {% if app.user %}
                            <a class="nav-link" href="{{ path('app_home') }}">Hoy</a>
                            <a class="nav-link" href="{{ path('app_predictions') }}">Predicciones</a>
                            <a class="nav-link" href="{{ path('app_leaderboard') }}">Tabla de posiciones</a>
                            <a class="nav-link" href="{{ path('app_phases') }}">Fases</a>
                            <a class="nav-link" href="{{ path('app_rules') }}">Reglas</a>
                            <a class="nav-link" href="{{ path('app_profile') }}">Mi cuenta</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a class="nav-link" href="{{ path('admin_dashboard') }}">Admin</a>
                            {% endif %}
                            <a class="nav-link" href="{{ path('app_logout') }}">Cerrar sesión</a>
                        {% else %}
                            <a class="nav-link" href="{{ path('app_rules') }}">Reglas</a>
                            <a class="nav-link" href="{{ path('app_login') }}">Iniciar sesión</a>
                            <a class="nav-link" href="{{ path('app_register') }}">Registrarse</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <main class="container pb-5">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
