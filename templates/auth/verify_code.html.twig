{% extends 'base.html.twig' %}

{% block title %}Verificar correo{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Validar código</h2>
                <p class="text-muted">Ingresa el correo y el código de 6 dígitos que llegó por email.</p>
                <form method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('verify_code') }}">
                    <div class="mb-3">
                        <label class="form-label">Correo</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Código</label>
                        <input type="text" name="code" maxlength="6" class="form-control" required>
                    </div>
                    <button class="btn btn-primary w-100">Verificar</button>
                </form>

                <hr>
                <p class="text-muted mb-2">Si tu código expiró, solicita uno nuevo:</p>
                <form method="post" action="{{ path('app_verify_resend') }}" class="d-flex gap-2 align-items-end">
                    <input type="hidden" name="_token" value="{{ csrf_token('verify_resend') }}">
                    <div class="flex-grow-1">
                        <label class="form-label">Correo</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>
                    <button class="btn btn-outline-dark">Reenviar</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
