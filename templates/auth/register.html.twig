{% extends 'base.html.twig' %}

{% block title %}Registro{% endblock %}

{% block body %}
<div class="auth-shell auth-shell--register">
    <div class="auth-card card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h2 class="auth-title h4 mb-1">Registro</h2>
            <p class="auth-subtitle mb-4">Crea tu cuenta para guardar tus predicciones y competir en la tabla.</p>

            {{ form_start(registrationForm, {attr: {class: 'auth-form'}}) }}
                <div class="auth-field">
                    {{ form_label(registrationForm.name, 'Nombre', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(registrationForm.name, {attr: {class: 'form-control', placeholder: 'Tu nombre'}}) }}
                    {{ form_errors(registrationForm.name) }}
                </div>

                <div class="auth-field">
                    {{ form_label(registrationForm.email, 'Correo', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(registrationForm.email, {attr: {class: 'form-control', placeholder: 'tu@email.com', autocomplete: 'email'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="auth-field">
                    {{ form_label(registrationForm.plainPassword, 'Contraseña', {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {attr: {class: 'form-control', autocomplete: 'new-password', placeholder: 'Mínimo 12 caracteres'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                {{ form_widget(registrationForm.captcha) }}

                <button class="btn btn-primary w-100 mt-2">Crear cuenta</button>
            {{ form_end(registrationForm, {render_rest: false}) }}

            <div class="auth-divider"><span>o</span></div>
            <a class="btn btn-outline-dark w-100 btn-google" href="{{ path('connect_google_start') }}">
                <svg class="google-logo" viewBox="0 0 48 48" width="18" height="18" style="width:18px;height:18px;vertical-align:-0.2em;margin-right:.45rem;" aria-hidden="true" focusable="false">
                    <path fill="#FFC107" d="M43.611 20.083h-1.611V20H24v8h11.303C33.654 32.657 29.218 36 24 36c-6.617 0-12-5.383-12-12s5.383-12 12-12c3.055 0 5.84 1.152 7.959 3.041l5.657-5.657C34.046 6.053 29.277 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/>
                    <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.055 0 5.84 1.152 7.959 3.041l5.657-5.657C34.046 6.053 29.277 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/>
                    <path fill="#4CAF50" d="M24 44c5.176 0 9.862-1.977 13.409-5.196l-6.19-5.238C29.144 35.091 26.688 36 24 36c-5.196 0-9.617-3.318-11.283-7.946l-6.522 5.025C9.506 39.556 16.227 44 24 44z"/>
                    <path fill="#1976D2" d="M43.611 20.083h-1.611V20H24v8h11.303a12.083 12.083 0 0 1-4.084 5.566h-.002l6.19 5.238C36.971 39.201 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/>
                </svg>
                <span>Continuar con Google</span>
            </a>
            <p class="auth-footnote mt-3 mb-0 text-center">¿Ya tienes cuenta? <a href="{{ path('app_login') }}">Entrar</a></p>
        </div>
    </div>
    <div class="auth-glow" aria-hidden="true"></div>
</div>
{% endblock %}
