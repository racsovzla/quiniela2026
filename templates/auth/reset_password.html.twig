{% extends 'base.html.twig' %}

{% block title %}Nueva contraseña{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-card card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h2 class="auth-title h4 mb-1">Nueva contraseña</h2>
            <p class="auth-subtitle mb-4">Elige una contraseña nueva para tu cuenta.</p>

            {{ form_start(resetForm, {attr: {class: 'auth-form'}}) }}
                <div class="auth-field">
                    {{ form_label(resetForm.plainPassword.first, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="password-field">
                        {{ form_widget(resetForm.plainPassword.first, {attr: {class: 'form-control', placeholder: 'Mínimo 8 caracteres'}}) }}
                        <button
                            type="button"
                            class="password-toggle"
                            data-toggle-password="{{ resetForm.plainPassword.first.vars.id }}"
                            aria-label="Mostrar contraseña"
                            title="Mostrar u ocultar contraseña"
                        ><span aria-hidden="true">👁</span></button>
                    </div>
                    <small class="text-body-secondary d-block mt-1">Debe tener al menos 8 caracteres e incluir mayúscula, minúscula y número.</small>
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>

                <div class="auth-field">
                    {{ form_label(resetForm.plainPassword.second, null, {label_attr: {class: 'form-label'}}) }}
                    <div class="password-field">
                        {{ form_widget(resetForm.plainPassword.second, {attr: {class: 'form-control', placeholder: 'Repite tu contraseña'}}) }}
                        <button
                            type="button"
                            class="password-toggle"
                            data-toggle-password="{{ resetForm.plainPassword.second.vars.id }}"
                            aria-label="Mostrar confirmación de contraseña"
                            title="Mostrar u ocultar contraseña"
                        ><span aria-hidden="true">👁</span></button>
                    </div>
                    {{ form_errors(resetForm.plainPassword.second) }}
                    {{ form_errors(resetForm.plainPassword) }}
                </div>

                <button class="btn btn-primary w-100 mt-2">Guardar contraseña</button>
            {{ form_end(resetForm) }}
        </div>
    </div>
    <div class="auth-glow" aria-hidden="true"></div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            if (document.documentElement.dataset.passwordToggleBound === '1') {
                return;
            }

            document.addEventListener('click', (event) => {
                const button = event.target.closest('[data-toggle-password]');
                if (!button) {
                    return;
                }

                const targetId = button.getAttribute('data-toggle-password');
                const input = targetId ? document.getElementById(targetId) : null;
                if (!input) {
                    return;
                }

                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                const icon = button.querySelector('span');
                if (icon) {
                    icon.textContent = isPassword ? '🙈' : '👁';
                }
            });

            document.documentElement.dataset.passwordToggleBound = '1';
        })();
    </script>
{% endblock %}
