{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block head_meta %}<meta name="turbo-cache-control" content="no-cache">{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Iniciar sesión</h2>

                {% if error %}
                    <div class="alert alert-danger">Credenciales inválidas.</div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}" data-turbo="false">
                    <div class="mb-3">
                        <label class="form-label">Correo</label>
                        <input type="email" name="_username" value="{{ last_username }}" class="form-control" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" name="_password" class="form-control" required>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" id="_remember_me" name="_remember_me" checked>
                        <label class="form-check-label" for="_remember_me">Mantener sesión iniciada</label>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="/">
                    <button class="btn btn-primary w-100">Entrar</button>
                </form>

                <p class="mt-3 mb-0 text-center small text-body-secondary">
                    ¿No tienes cuenta? <a href="{{ path('app_register') }}">Créala aquí</a>.
                    ¿Olvidaste tu contraseña? <a href="{{ path('app_request_password_reset') }}">Recupérala aquí</a>.
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
