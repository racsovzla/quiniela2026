{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Iniciar sesión</h2>

                {% if error %}
                    <div class="alert alert-danger">Credenciales inválidas.</div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Correo</label>
                        <input type="email" name="_username" value="{{ last_username }}" class="form-control" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" name="_password" class="form-control" required>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button class="btn btn-primary w-100">Entrar</button>
                </form>

                <hr>
                <a class="btn btn-outline-dark w-100" href="{{ path('connect_google_start') }}">Entrar con Google</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
