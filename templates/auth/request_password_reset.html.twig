{% extends 'base.html.twig' %}

{% block title %}Recuperar contraseña{% endblock %}

{% block body %}
<div class="auth-shell">
    <div class="auth-card card shadow-sm">
        <div class="card-body p-4 p-md-5">
            <h2 class="auth-title h4 mb-1">Recuperar contraseña</h2>
            <p class="auth-subtitle mb-4">Indica el correo de tu cuenta y te enviaremos un enlace para restablecerla.</p>

            {{ form_start(requestForm, {attr: {class: 'auth-form'}}) }}
                <div class="auth-field">
                    {{ form_label(requestForm.email, null, {label_attr: {class: 'form-label'}}) }}
                    {{ form_widget(requestForm.email, {attr: {class: 'form-control'}}) }}
                    {{ form_errors(requestForm.email) }}
                </div>

                <button class="btn btn-primary w-100 mt-2">Enviar enlace</button>
            {{ form_end(requestForm) }}

            <p class="auth-footnote mt-3 mb-0 text-center">
                <a href="{{ path('app_login') }}">Volver al inicio de sesión</a>
            </p>
        </div>
    </div>
    <div class="auth-glow" aria-hidden="true"></div>
</div>
{% endblock %}
