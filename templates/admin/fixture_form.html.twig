{% extends 'base.html.twig' %}

{% block title %}Partido{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-dark text-white py-3">
                <h1 class="h5 mb-0 fw-semibold"><i class="bi bi-pencil-square me-2"></i>Editor de Partido</h1>
            </div>
            <div class="card-body p-4 p-md-5">
                {{ form_start(form) }}
                    
                    <h5 class="border-bottom pb-2 mb-4 text-secondary">Equipos y Grupo</h5>
                    <div class="row g-3 mb-4 align-items-center">
                        <div class="col-md-5">
                            {{ form_row(form.homeTeam, {
                                'label': 'Equipo Local',
                                'attr': {'class': 'form-select form-select-lg'}
                            }) }}
                        </div>
                        <div class="col-md-2 text-center">
                            <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary fw-bold">VS</span>
                        </div>
                        <div class="col-md-5">
                            {{ form_row(form.awayTeam, {
                                'label': 'Equipo Visitante',
                                'attr': {'class': 'form-select form-select-lg'}
                            }) }}
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            {{ form_row(form.group, {
                                'label': 'Grupo',
                                'attr': {'class': 'form-select'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.kickoffAt, {
                                'label': 'Fecha y Hora (UTC)',
                                'attr': {'class': 'form-control'}
                            }) }}
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-4 mt-5 text-secondary">Fase del torneo</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            {{ form_row(form.stage, {
                                'label': 'Fase',
                                'attr': {'class': 'form-select', 'id': 'fixture_stage'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.fifaMatchId, {
                                'label': 'FIFA Match ID',
                                'help': 'ID usado para sincronizar con FIFA',
                                'attr': {'class': 'form-control'}
                            }) }}
                        </div>
                    </div>

                    <h5 class="border-bottom pb-2 mb-4 mt-5 text-secondary">Estado y Resultado</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            {{ form_row(form.status, {
                                'label': 'Estado del Partido',
                                'attr': {'class': 'form-select'}
                            }) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.homeScore, {
                                'label': 'Goles Local',
                                'attr': {'class': 'form-control text-center fs-4 fw-bold fixture-score-input', 'placeholder': '-'}
                            }) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.awayScore, {
                                'label': 'Goles Visitante',
                                'attr': {'class': 'form-control text-center fs-4 fw-bold fixture-score-input', 'placeholder': '-'}
                            }) }}
                        </div>
                    </div>

                    {% set showFixturePenaltiesInitially = form.stage.vars.value != constant('App\\Entity\\Fixture::STAGE_GROUP')
                        and form.homeScore.vars.value is not null
                        and form.awayScore.vars.value is not null
                        and form.homeScore.vars.value == form.awayScore.vars.value %}
                    <div id="fixture-penalty-fields" class="row g-4 mb-4{% if not showFixturePenaltiesInitially %} d-none{% endif %}">
                        <div class="col-md-4">
                            <p class="form-text mb-0">Solo si el partido definió ganador por penales.</p>
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.penaltyHomeScore, {
                                'label': 'Penales local',
                                'attr': {'class': 'form-control text-center fs-4 fw-bold', 'placeholder': '-'}
                            }) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(form.penaltyAwayScore, {
                                'label': 'Penales visitante',
                                'attr': {'class': 'form-control text-center fs-4 fw-bold', 'placeholder': '-'}
                            }) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-5 pt-3 border-top">
                        {{ form_widget(form._token) }}
                        <a class="btn btn-outline-secondary px-4" href="{{ path('admin_dashboard') }}">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-5 fw-semibold">Guardar Partido</button>
                    </div>

                    {% if form.vars.submitted and not form.vars.valid %}
                        <div class="alert alert-danger mt-4 mb-0" role="alert">
                            No se pudo guardar. Revisa los campos marcados.
                            {{ form_errors(form) }}
                        </div>
                    {% endif %}

                {{ form_end(form, { render_rest: false }) }}
            </div>
        </div>
        <script>
            (() => {
                const stageSelect = document.getElementById('fixture_stage');
                const penaltyBlock = document.getElementById('fixture-penalty-fields');
                if (!stageSelect || !penaltyBlock) return;

                const groupStage = {{ constant('App\\Entity\\Fixture::STAGE_GROUP')|json_encode|raw }};
                const scoreInputs = document.querySelectorAll('.fixture-score-input');

                const toggleFixturePenalties = () => {
                    const isKnockout = stageSelect.value !== groupStage;
                    const home = parseInt(document.querySelector('#{{ form.homeScore.vars.id }}')?.value ?? '', 10);
                    const away = parseInt(document.querySelector('#{{ form.awayScore.vars.id }}')?.value ?? '', 10);
                    const show = isKnockout && !Number.isNaN(home) && !Number.isNaN(away) && home === away;
                    penaltyBlock.classList.toggle('d-none', !show);
                    if (!show) {
                        penaltyBlock.querySelectorAll('input').forEach((input) => { input.value = ''; });
                    }
                };

                stageSelect.addEventListener('change', toggleFixturePenalties);
                scoreInputs.forEach((input) => input.addEventListener('input', toggleFixturePenalties));
                toggleFixturePenalties();
            })();
        </script>

        {% if predictions is defined and fixture is defined %}
            <div class="card shadow-sm border-0 rounded-3 mt-4">
                <div class="card-header bg-dark text-white py-3">
                    <h2 class="h5 mb-0 fw-semibold"><i class="bi bi-card-list me-2"></i>Pronósticos de los Usuarios</h2>
                </div>
                <div class="card-body p-4">
                    <p class="text-body-secondary small">Como admin puedes editar o crear pronósticos sin importar si el partido ya finalizó.</p>
                    {% if predictions is not empty or missingUsers is not empty %}
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h3 class="h6 border-bottom pb-2 mb-3 text-secondary"><i class="bi bi-check-circle-fill text-success me-1"></i>Cargadas ({{ predictions|length }})</h3>
                                {% if predictions is not empty %}
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle table-hover mb-0 admin-predictions-table">
                                            <thead>
                                                <tr>
                                                    <th>Participante</th>
                                                    <th>Pronóstico</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for prediction in predictions %}
                                                    <tr>
                                                        <td class="align-middle admin-predictions-table__participant">
                                                            <span class="text-truncate d-inline-block" title="{{ prediction.user.name }}">{{ prediction.user.name }}</span>
                                                        </td>
                                                        <td>
                                                            {% include 'admin/_prediction_form.html.twig' with {
                                                                fixture: fixture,
                                                                user: prediction.user,
                                                                p: prediction,
                                                            } %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% else %}
                                    <p class="text-muted small mb-0">Ningún participante ha cargado aún.</p>
                                {% endif %}
                            </div>

                            <div class="col-md-6">
                                <h3 class="h6 border-bottom pb-2 mb-3 text-secondary"><i class="bi bi-exclamation-circle-fill text-warning me-1"></i>Pendientes ({{ missingUsers|length }})</h3>
                                {% if missingUsers is not empty %}
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle table-hover mb-0 admin-predictions-table">
                                            <thead>
                                                <tr>
                                                    <th>Participante</th>
                                                    <th>Pronóstico</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for user in missingUsers %}
                                                    <tr>
                                                        <td class="align-middle admin-predictions-table__participant">
                                                            <span class="text-truncate d-inline-block" title="{{ user.name }}">{{ user.name }}</span>
                                                        </td>
                                                        <td>
                                                            {% include 'admin/_prediction_form.html.twig' with {
                                                                fixture: fixture,
                                                                user: user,
                                                                p: null,
                                                            } %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% else %}
                                    <p class="text-muted small mb-0">¡Todos los participantes han cargado sus predicciones!</p>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0 text-center py-3">No hay participantes habilitados en el sistema.</p>
                    {% endif %}
                </div>
            </div>
            <script>
                document.querySelectorAll('.admin-prediction-form').forEach((form) => {
                    const togglePenalties = () => {
                        const block = form.querySelector('.penalty-inputs');
                        if (!block || form.dataset.knockout !== '1') return;
                        const home = parseInt(form.querySelector('input[name="home"]')?.value ?? '', 10);
                        const away = parseInt(form.querySelector('input[name="away"]')?.value ?? '', 10);
                        const show = !Number.isNaN(home) && !Number.isNaN(away) && home === away;
                        block.classList.toggle('d-none', !show);
                        if (!show) block.querySelectorAll('input').forEach((i) => { i.value = ''; });
                    };
                    form.querySelectorAll('input[name="home"], input[name="away"]').forEach((input) => {
                        input.addEventListener('input', togglePenalties);
                    });
                    togglePenalties();
                });
            </script>
        {% endif %}
    </div>
</div>
{% endblock %}
