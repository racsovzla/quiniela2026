{% extends 'emails/layout.html.twig' %}

{% block body %}
    <h2 style="margin:0 0 8px 0;font-size:24px;font-weight:800;color:#ffffff;">Recuperar contraseña</h2>
    <p style="margin:0 0 24px 0;font-size:14px;color:#9cb3c5;">Hola <strong style="color:#e8f1f7;">{{ user.name }}</strong>, recibimos una solicitud para restablecer tu contraseña.</p>

    <p style="margin:0 0 20px 0;font-size:15px;color:#e8f1f7;">Haz clic en el botón para elegir una contraseña nueva:</p>

    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
        <tr>
            <td align="center">
                <a href="{{ resetUrl }}" style="display:inline-block;background-color:#00a86b;color:#ffffff;font-size:16px;font-weight:700;text-decoration:none;padding:14px 36px;border-radius:8px;letter-spacing:0.5px;">Restablecer contraseña</a>
            </td>
        </tr>
    </table>

    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:16px;">
        <tr>
            <td style="background-color:#13283a;border:1px solid #224057;border-radius:6px;padding:12px 16px;">
                <p style="margin:0 0 6px 0;font-size:12px;color:#9cb3c5;">Si el botón no funciona, copia este enlace en tu navegador:</p>
                <p style="margin:0;font-size:12px;color:#2ec4ff;word-break:break-all;">{{ resetUrl }}</p>
            </td>
        </tr>
    </table>

    <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr>
            <td style="background-color:#1a1a0a;border:1px solid #3a3010;border-left:4px solid #f5b700;border-radius:6px;padding:12px 16px;">
                <p style="margin:0;font-size:13px;color:#f5b700;">⏰ Este enlace expira en <strong>{{ expiresMinutes }} minutos</strong>.</p>
            </td>
        </tr>
    </table>

    <p style="margin:20px 0 0 0;font-size:13px;color:#9cb3c5;">Si no solicitaste este cambio, ignora este correo.</p>
{% endblock %}
