{% extends 'base.html.twig' %}

{% block title %}Predicciones{% endblock %}

{% block body %}
<h1 class="h3 mb-3">Predicciones</h1>

{% if not canParticipate %}
    <div class="alert alert-warning">Debes verificar tu correo para guardar predicciones. Cuando termines ese paso, este panel se desbloquea.</div>
{% elseif paymentValidatedAt is null %}
    <div class="alert alert-info">Ya puedes cargar predicciones. Sumarás puntos solo a partir de que el admin valide tu pago.</div>
{% else %}
    <div class="alert alert-success">Pago validado. Sumas puntos para partidos con kickoff desde <span class="js-local-datetime" data-utc="{{ paymentValidatedAt|date('c') }}">{{ paymentValidatedAt|date('Y-m-d H:i') }} UTC</span>.</div>
{% endif %}

{% if canParticipate %}
    {% if pendingCount > 0 %}
        <div class="alert alert-danger shadow-sm border-0 border-start border-danger border-4">
            <strong>¡Atención!</strong> Tienes <strong>{{ pendingCount }}</strong> predicci{{ pendingCount == 1 ? 'ón' : 'ones' }} pendiente{{ pendingCount == 1 ? '' : 's' }} por llenar.
        </div>
    {% else %}
        <div class="alert alert-info shadow-sm border-0 border-start border-info border-4">
            <strong>¡Excelente!</strong> Tienes todas tus predicciones disponibles al día.
        </div>
    {% endif %}
{% endif %}

<p class="screen-note mb-3">Tip: solo se guardan filas con marcador completo. En eliminatorias, si pronosticas empate debes indicar también los penales.</p>

{% if canParticipate %}
<div class="d-flex justify-content-end mb-2 gap-2 align-items-center">
    <span id="save-all-feedback" class="text-success fw-semibold" aria-live="polite"></span>
    <button id="btn-save-all" class="btn btn-success">Guardar todo</button>
</div>
<div class="text-end mb-3">
    <small class="text-body-secondary">Se envían solo los partidos con marcador completo (y penales si aplica) y la ventana abierta.</small>
</div>
{% endif %}
<div class="mb-2">{% include '_daypart_legend.html.twig' %}</div>
<div class="table-responsive bg-white border rounded-3 shadow-sm predictions-page">
<table class="table align-middle mb-0 predictions-table">
    <thead>
        <tr>
            <th>Fase</th>
            <th>Partido</th>
            <th>Inicio local</th>
            <th>Tu predicción</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    {% for fixture in fixtures %}
        {% set p = predictionByFixture[fixture.id] ?? null %}
        {% set v = viewByFixture[fixture.id] %}
        {% set canEditFixture = v.canEdit %}
        {% set formDisabled = (not canParticipate) or (not v.canEdit) %}
        <tr>
            <td data-label="Fase">{{ fixture.knockout ? fixture.stageLabel : (fixture.group ? fixture.group.code : (fixture.homeTeam.group ? fixture.homeTeam.group.code : '-')) }}</td>
            <td data-label="Partido" class="predictions-table__match">{{ fixture.homeTeam.code|flag_icon }} {{ fixture.homeTeam.code|country_name_es(fixture.homeTeam.name) }} vs {{ fixture.awayTeam.code|flag_icon }} {{ fixture.awayTeam.code|country_name_es(fixture.awayTeam.name) }}</td>
            <td data-label="Inicio local"><span class="js-local-datetime" data-daypart data-utc="{{ fixture.kickoffAt|date('c') }}">{{ fixture.kickoffAt|date('Y-m-d H:i') }} UTC</span></td>
            <td data-label="Tu predicción">
                {% if formDisabled and not p %}
                    {# No editable y sin pronóstico: evitamos los inputs vacíos que
                       parecen un "0 - 0" cargado. No se guarda nada en BD. #}
                    <span class="text-body-secondary fst-italic">Sin pronóstico</span>
                {% else %}
                    {% include 'prediction/_form_fields.html.twig' with {
                        fixture: fixture,
                        p: p,
                        formDisabled: formDisabled,
                        canEditFixture: canEditFixture,
                    } %}
                {% endif %}
                {# Marcador real (final o en vivo) debajo de la predicción. #}
                {% if v.scoreboardText %}
                    <small class="d-block mt-1">Resultado: <span class="fw-semibold">{{ v.scoreboardText }}</span></small>
                {% endif %}
            </td>
            <td class="predictions-table__status">
                <span class="badge {{ v.statusClass }}">{{ v.statusLabel }}</span>

                {# Puntos obtenidos, solo si el usuario pronosticó. #}
                {% if p and v.pointsText %}
                    <small class="d-block {{ v.pointsClass }}">{{ v.pointsText }}</small>
                    {% if v.countsNote %}
                        <small class="d-block text-body-secondary">{{ v.countsNote }}</small>
                    {% endif %}
                {% endif %}

                {% if v.state == 'open' %}
                    <small class="d-block text-body-secondary mt-1 js-deadline-countdown" data-deadline="{{ v.deadlineIso }}"></small>
                {% elseif v.state == 'closed' and not canParticipate %}
                    <small class="d-block text-body-secondary mt-1">Verifica tu correo para habilitarla.</small>
                {% elseif v.state == 'closed' %}
                    <small class="d-block text-body-secondary mt-1">Ya pasó el cierre de este partido.</small>
                {% endif %}
            </td>
        </tr>
    {% else %}
        <tr><td colspan="5" class="text-center py-4">No hay partidos cargados aún.</td></tr>
    {% endfor %}
    </tbody>
</table>
</div>
{% endblock %}
