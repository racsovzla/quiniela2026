# Local database (recommended: dedicated app user)
DATABASE_URL="postgresql://app_user:app_password@127.0.0.1:5432/quiniela2026?serverVersion=17&charset=utf8"

# Local SMTP with Mailpit (default)
MAILER_DSN=smtp://127.0.0.1:1025
MAILER_FROM_EMAIL=no-reply@quiniela2026.local
MAILER_FROM_NAME="Quiniela 2026"

